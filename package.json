{
  "name": "@semore/mcp-adapter",
  "version": "0.0.1",
  "description": "MCP (Model Context Protocol) adapter — JSON-RPC 2.0 client + server scaffold for the Semore agentic-commerce 5-tool surface.",
  "license": "Apache-2.0",
  "author": "Semore Founding Team <semore.hq@gmail.com>",
  "homepage": "https://semore.net",
  "repository": {
    "type": "git",
    "url": "https://github.com/semore-hq/mcp-adapter.git"
  },
  "bugs": {
    "url": "mailto:semore.hq@gmail.com"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "json-rpc",
    "agentic-commerce",
    "semore",
    "ai-agents"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm typecheck && pnpm test && bash ./scripts/opsec-scan.sh \"$PWD\" && pnpm build"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
